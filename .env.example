# Copie para .env: copy .env.example .env

SECRET_KEY=altere-esta-chave-em-producao

# Conversão PDF:
#   auto     = gera PDF se LibreOffice existir; senão só DOCX (ideal no Windows dev)
#   required = falha se não conseguir PDF (produção estrita)
#   disabled = nunca gera PDF
PDF_CONVERSION=auto

# Linux/VPS/Docker (padrão após apt install libreoffice-writer-nogui):
# LIBREOFFICE_PATH=/usr/bin/soffice

# Windows (opcional, só se quiser PDF localmente):
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# DATABASE_URL=sqlite:///instance/contratos.db
# DATABASE_URL=postgresql://usuario:senha@localhost/contratos

# Railway (produção — ver RAILWAY.md):
# SECRET_KEY=gere-uma-chave-forte
# DATABASE_URL=          # referência automática ao Postgres do Railway
# PDF_CONVERSION=auto
# FLASK_DEBUG=0
